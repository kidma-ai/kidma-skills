{
  "$schema": "https://code.claude.com/schemas/marketplace.v2.json",
  "name": "kidma-plugins",
  "description": "Official Kidma plugin library for Claude Code — lesson planning, presentations, brand assets, and media generation for Kidma educators, plus developer git workflow tooling",
  "version": "2.2.0",
  "repository": "https://github.com/kidma-ai/kidma-skills",
  "owner": {
    "name": "Kidma Technologies and Education Ltd.",
    "email": "kidma2030@gmail.com",
    "homepage": "https://www.kid-ma.com"
  },
  "plugins": [
    { "name": "kidma-company",   "source": "./plugins/kidma-company" },
    { "name": "kidma-pedagogy",  "source": "./plugins/kidma-pedagogy" },
    { "name": "kidma-marketing", "source": "./plugins/kidma-marketing" },
    { "name": "kidma-media",     "source": "./plugins/kidma-media" },
    { "name": "kidev",           "source": "./plugins/kidev" }
  ],
  "bundles": [
    {
      "name": "kidma-lesson-full",
      "description": "Full lesson pipeline — blank topic → branded .docx + student exercise PDF",
      "plugins": ["kidma-company", "kidma-pedagogy"],
      "pipeline": [
        { "step": 1, "skill": "lesson-planner",  "produces": "lesson_content.json" },
        { "step": 2, "skill": "lesson-to-word",  "consumes": "lesson_content.json", "produces": "lesson_plan.docx" },
        { "step": 3, "skill": "lesson-exercise", "consumes": "lesson_content.json", "produces": "lesson_summary.pdf" }
      ]
    },
    {
      "name": "kidma-presentation-full",
      "description": "Full lesson presentation pipeline — lesson content → branded .pptx",
      "plugins": ["kidma-company", "kidma-pedagogy"],
      "pipeline": [
        { "step": 1, "skill": "slides-planner", "produces": "presentation_plan.txt" },
        { "step": 2, "skill": "slides-builder", "consumes": "presentation_plan.txt", "produces": "presentation.pptx" }
      ]
    },
    {
      "name": "kidma-article-full",
      "description": "Full article pipeline — topic brief → Hebrew article draft + matching Nano Banana image prompts",
      "plugins": ["kidma-company", "kidma-marketing"],
      "pipeline": [
        { "step": 1, "skill": "write-article",        "produces": "article.md" },
        { "step": 2, "skill": "article-image-prompt", "consumes": "article.md", "produces": "image_prompts.txt" }
      ]
    }
  ]
}
